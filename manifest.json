{
  "manifest_version": 3,
  "name": "Quiz Assister for Binogi",
  "version": "1.2.0",
  "description": "Quiz assistant for binogi with a clean Ui.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
